DATABASE_URL=postgresql://user:password@127.0.0.1:5432/remindme
PORT=3333

# notify-api (gateway do Telegram)
NOTIFY_API_URL=http://localhost:3334
NOTIFY_API_KEY=
# Segredo conferido no header x-callback-secret quando a notify-api repassa os cliques
CALLBACK_SECRET=

# URL pública COMPLETA do frontend (ex: https://remind.seudominio.com), usada nos
# botões "Outro horário" e "Cancelar". Deixe vazio para não enviar botões de URL
# (útil em dev sem domínio público). URL inválida faz o Telegram recusar o envio.
WEB_URL=
