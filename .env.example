# ===== Docker Compose (docker compose up) =====
# Credenciais do banco (container dedicado).
# IMPORTANTE: a senha é embutida na DATABASE_URL pelo compose, então evite
# caracteres que quebram URL (@ : / ? # % &). Use letras/números/._- à vontade.
POSTGRES_USER=remindme
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=remindme

# Domínio servido pelo proxy reverso central (Caddy). Crie o registro DNS no
# Cloudflare apontando para a VPN. O proxy termina o TLS automaticamente.
REMINDME_DOMAIN=remind.gomeslab.tech

# API key do projeto RemindMe cadastrado na notify-api (resposta do POST /api/projects)
NOTIFY_API_KEY=

# Segredo conferido quando a notify-api repassa os cliques de botão.
# Use o MESMO valor no callback_secret do projeto cadastrado na notify-api.
CALLBACK_SECRET=

# URL pública COMPLETA do frontend (ex: https://remind.seudominio.com), usada nos
# botões "Outro horário"/"Cancelar". Deixe VAZIO para não enviar botões de URL.
# Atenção: uma URL inválida (ex: localhost ou sem domínio) faz o Telegram recusar o envio.
WEB_URL=
